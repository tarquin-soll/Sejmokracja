title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
!}

= Status

[+ month : month +] [+ year +]

Resources available: [+ resources +]

PPS position: [? if pps_toleration : toleration ?][? if pps_in_government : in government - ?][? if pps_toleration == 0 and pps_in_government == 0 : opposition ?]
[? if in_weimar_coalition and spd_in_government: Weimar Coalition ?][? if in_grand_coalition and spd_in_government: Grand Coalition ?][? if in_popular_front and spd_in_government: Popular Front ?][? if in_left_front and spd_in_government: Left Front ?][? if in_spd_majority and spd_in_government: SPD majority ?][? if in_minority_government and spd_in_government: minority government ?][? if in_emergency_government and spd_in_government: emergency government ?]

[? if spd_in_government and not in_spd_majority and not in_left_front : Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

[? if spd_in_government and (in_left_front or in_popular_front): KPD coalition dissent: [+ kpd_coalition_dissent : coalition_dissent +] ?]

Internal dissent: [+ dissent_percent : dissent +]

= Government

President: [+ president +]

Chancellor: [+ chancellor +] ([+ chancellor_party +])

Ssjm composition:

[? if pps_in_government = 1 : Budget: [+ budget +] ?]

Next election: [+ next_election_month : month +] [+ next_election_year +]

= Economics

Inflation: [+ inflation_2 +]%

[? if black_thursday_seen = 1 : Unemployment: [+ unemployed_2 +]% ?]

Economic growth: [+ economic_growth_2 +]%

[? if kprp_formed: <span style="color: #890000;"><span class="tooltip-text" title="[+ kprp_full_name +]"><b>[+ kprp_name +]</b></span></span>: [+ kprp_sj +]% ?] <span style="color: #C62828;"><span class="tooltip-text" title="Polish Socialist Party"><b>PPS</b></span></span>: [+ pps_sj +]% <span style="color: #841839;"><span class="tooltip-text" title="National Workers' Party"><b>NPR</b></span></span>: [+ npr_sj +]% <span style="color: #80FF00;"><span class="tooltip-text" title="Polish People's Party - Left"><b>PSL-L</b></span></span>: [+ psl_l_sj +]% [? if chsr_formed: <span style="color: #43C46C;"><span class="tooltip-text" title="Radical Peasant Party"><b>ChSR</b></span></span>: [+ chsr_sj +]% ?] <span style="color: #179900;"><span class="tooltip-text" title="Polish People's Party - Liberation"><b>PSL-W</b></span></span>: [+ psl_w_sj +]% <span style="color: #3A6538;"><span class="tooltip-text" title="Polish People's Party - Piast"><b>PSL-P</b></span></span>: [+ psl_p_sj +]% <span style="color: #FFF480;"><span class="tooltip-text" title="Ukrainian Parties"><b>PU</b></span></span>: [+ pu_sj +]% [? if bmn_formed: <span style="color: #E3AF34;"><span class="tooltip-text" title="Bloc of National Minorities"><b>BMN</b></span></span>: [+ bmn_sj +]% ?] <span style="color: #C40000;"><span class="tooltip-text" title="Jewish Parties"><b>PZ</b></span></span>: [+ pz_sj +]% <span style="color: #FFD700;"><span class="tooltip-text" title="Polish Centre"><b>PC</b></span></span>: [+ pc_sj +]% [? if chzjn_formed: <span style="color: #312E99;"><span class="tooltip-text" title="[+ chzjn_full_name +]"><b>[+ chzjn_name +]</b></span></span>: [+ chzjn_sj +]% ?] <span style="color: #909090;"><b>Others</b></span>: [+ other_sj +]%

