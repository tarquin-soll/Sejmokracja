title: Sejm Elections
new-page: true
tags: event
priority: -1
view-if: (year = next_election_year and month >= next_election_month) or (year > next_election_year)
on-departure: month_actions += 1; in_election = 0; next_election_year = next_election_year + 4; n_elections += 1; next_election_time = time + 48; papen_chancellor_timer = 4;
set-jump: post_election_1922_sejm
face-image: img/fl_pl.webp

= Elections, [+ month : month +] [+ year +]

The Sejm elections are to be held now.

- @election_algorithm: May we do our best...


@post_election_1922_sejm
on-arrival: {!
var new_party_sum = 0;
for (var party of Q.parties) {
    Q['old_' + party + '_sj'] = Q[party + '_sj'];
    if (Q[party + '_votes'] < Q.electoral_threshold || (Q.electoral_threshold > 1 && party == 'other') || Q[party + '_banned'] || Q[party + '_boycott']) {
        Q[party + '_sj'] = 0;
    } else {
        Q[party + '_sj'] = Q[party + '_votes'];
    }
    new_party_sum += Q[party + '_sj'];
    Q[party + '_sj_disp'] = Q[party + '_sj'].toFixed(1);
    Q['change_' + party + '_sj'] = Q[party + '_sj'] - Q['old_' + party + '_sj'];
    var sign = Q['change_' + party + '_sj'] > 0 
                   ? '<img src="img/arrowup.png"> ' 
                   : Q['change_' + party + '_sj'] < 0 
                     ? '<img src="img/arrowdown.png"> ' 
                     : '<img src="img/steady.png"> ';
    Q['str_change_' + party] = sign + Q['change_' + party + '_sj'].toFixed(1);
}

Q.leverage = Q.pps_sj;

// Reset government and ministers

Q.coalition_dissent = 0;
Q.other_coalition_dissent = 0;

Q.kpp_in_government = 0;
Q.pps_in_government = 0;
Q.npr_in_government = 0;
Q.psl_l_in_government = 0;
Q.psl_w_in_government = 0;
Q.psl_p_in_government = 0;
Q.bmn_in_government = 0;
Q.zln_in_government = 0;
Q.pschd_in_government = 0;
Q.other_in_government = 0;
Q.otherright_in_government = 0;

Q.pps_attempt = 0;
Q.zln_attempt = 0;
Q.psl_w_attempt = 0;
Q.psl_p_attempt = 0;
Q.president_caretaker_government = 0;

Q.minority_government = 0;
Q.pps_toleration = 0;

Q.prime_minister_party = 'Vacant';
Q.prime_minister = 'Vacant';
Q.labor_minister_party = 'Vacant';
Q.labor_minister = 'Vacant';
Q.treasury_minister_party = 'Vacant';
Q.treasury_minister = 'Vacant';
Q.agriculture_minister_party = 'Vacant';
Q.agriculture_minister = 'Vacant';
Q.exterior_minister_party = 'Vacant';
Q.exterior_minister = 'Vacant';
Q.interior_minister_party = 'Vacant';
Q.interior_minister = 'Vacant';
Q.military_minister_party = 'Vacant';
Q.military_minister = 'Vacant';
Q.justice_minister_party = 'Vacant';
Q.justice_minister = 'Vacant';
Q.education_minister_party = 'Vacant';
Q.education_minister = 'Vacant';

Q.coalition_mandate = 0;
Q.other_coalition_mandate = 0;

// coalitions
Q.weimar_coalition = Q.spd_r + Q.ddp_r + Q.z_r - 3;

Q.strike_term_seen = 0;


var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_sj'];
}
Q.election_records.push(election_result);
!}
on-display: {!
data = [
    {
        "id": "kpp",
        "legend": "KPP",
        "name": "KPP",
        "seats": Math.round(Q.kpp_sj*4.44),
    },
    {
        "id": "pps",
        "legend": "PPS",
        "name": "PPS",
        "seats": Math.round(Q.pps_sj*4.44),
    },
    {
        "id": "npr",
        "legend": "NPR",
        "name": "NPR",
        "seats": Math.round(Q.npr_sj*4.44),
    },
    {
        "id": "psl_l",
        "legend": "PSL-L",
        "name": "PSL-L",
        "seats": Math.round(Q.psl_l_sj*4.44),
    },
    {
        "id": "psl_w",
        "legend": "PSL-W",
        "name": "PSL-W",
        "seats": Math.round(Q.psl_w_sj*4.44),
    },
    {
        "id": "psl_p",
        "legend": "PSL-P",
        "name": "PSL-P",
        "seats": Math.round(Q.psl_p_sj*4.44),
    },
    {
        "id": "bmn",
        "legend": "BMN",
        "name": "BMN",
        "seats": Math.round(Q.bmn_sj*4.44),
    },
    {
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.other_sj*4.44),
    },
    {
        "id": "zln",
        "legend": "ZLN",
        "name": "ZLN",
        "seats": Math.round(Q.zln_sj*4.44),
    },
    {
        "id": "pschd",
        "legend": "PSChD",
        "name": "PSChD",
        "seats": Math.round(Q.pschd_sj*4.44),
    },
    {
        "id": "otherright",
        "legend": "Other Parties",
        "name": "Other Parties",
        "seats": Math.round(Q.otherright_sj*4.44),
    },
];

if (window && d3) {
    var width = 500; 
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);
}
!}
go-to: pm_appoint

= Election results

{!<svg id="reichstag" style="width: 500px; height: 250px;"> </svg>!}

{!<table>!} 
{!<tr><td>Party</td><td>Vote share</td><td>% Change</td></tr>!}
{!<tr><td><div class="box" style='background-color:#C62828; outline: 2px; outline-style: solid;'> </div> !} **PPS:** {!</td><td>!} **[+ pps_sj +]%** {!</td><td>!} **[+ str_change_pps +]** {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#890000'> </div> !}KPP: {!</td><td>!} [+ kpp_sj +]% {!</td><td>!} [+ str_change_kpp +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#841839'> </div> !}NPR: {!</td><td>!} [+ npr_sj +]% {!</td><td>!} [+ str_change_npr +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#80FF00'> </div> !}PSL-L: {!</td><td>!} [+ psl_l_sj +]% {!</td><td>!} [+ str_change_psl_l +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#179900'> </div> !}PSL-W: {!</td><td>!} [+ psl_w_sj +]% {!</td><td>!} [+ str_change_psl_w +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#3A6538'> </div> !}PSL-P: {!</td><td>!} [+ psl_p_sj +]% {!</td><td>!} [+ str_change_psl_p +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#E3AF34'> </div> !}BMN: {!</td><td>!} [+ bmn_sj +]% {!</td><td>!} [+ str_change_bmn +] {!</td></tr>!}

{!<tr><td>- <div class="box" style='background-color:#302060'> </div> !}ChZJN: {!</td><td>!} volk% {!</td><td>!} skibidi {!</td></tr>!}

{!<tr><td style="padding-left:26px;"><div class="box" style='background-color:#312E99'></div> !}ZLN: {!</td><td>!} [+ zln_sj +]% {!</td><td>!} [+ str_change_zln +] {!</td></tr>!}

{!<tr><td style="padding-left:26px;"><div class="box" style='background-color:#316EAA'></div> !}PSChD: {!</td><td>!} [+ pschd_sj +]% {!</td><td>!} [+ str_change_pschd +] {!</td></tr>!}

{!<tr><td style="padding-left:26px;"><div class="box" style='background-color:#A0A0E0'></div> !}Other parties: {!</td><td>!} [+ otherright_sj +]% {!</td><td>!} [+ str_change_otherright +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#909090'> </div> !}Others: {!</td><td>!} [+ other_sj +]% {!</td><td>!} [+ str_change_other +] {!</td></tr>!}


{!</table>!}

